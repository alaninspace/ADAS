@page "/"
@using Microsoft.AspNetCore.SignalR.Client
@using Adas.Web.Services
@inject NavigationManager Navigation
@inject ChatStateService ChatState
@implements IAsyncDisposable
@implements IDisposable

<PageTitle>ADAS Premium Chat</PageTitle>

<style>
    .glass-panel {
        background: var(--mud-palette-surface);
        opacity: 0.95;
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(0, 205, 225, 0.3); /* Cyan accent border */
        box-shadow: 0 4px 30px rgba(0, 205, 225, 0.1);
        border-radius: 12px;
    }
    .glass-input {
        background: var(--mud-palette-surface);
        border: 1px solid rgba(15, 90, 211, 0.5); /* MidBlue accent border */
        border-radius: 8px;
    }
    .user-msg {
        background: rgba(15, 90, 211, 0.15); /* MidBlue tint */
        border: 1px solid rgba(15, 90, 211, 0.3);
    }
    .agent-msg {
        background: rgba(0, 205, 225, 0.1); /* Cyan tint */
        border: 1px solid rgba(0, 205, 225, 0.2);
    }
    .error-msg {
        background: rgba(220, 53, 69, 0.1); /* Red tint */
        border: 1px solid rgba(220, 53, 69, 0.3);
        color: var(--mud-palette-error);
    }
    
    /* 8-dot pulsing loader (4x2 grid) */
    .dot-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 6px;
        width: 32px;
        margin: 8px 0;
    }
    .dot-grid .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background-color: var(--mud-palette-primary);
        animation: pulse 1.5s infinite ease-in-out;
    }
    .dot-grid .dot:nth-child(1) { animation-delay: 0.1s; background-color: #00CDE1; } /* Cyan */
    .dot-grid .dot:nth-child(2) { animation-delay: 0.2s; background-color: #00FF00; } /* Green */
    .dot-grid .dot:nth-child(3) { animation-delay: 0.3s; background-color: #0F5AD3; } /* MidBlue */
    .dot-grid .dot:nth-child(4) { animation-delay: 0.4s; background-color: #00CDE1; }
    .dot-grid .dot:nth-child(5) { animation-delay: 0.5s; background-color: #00FF00; }
    .dot-grid .dot:nth-child(6) { animation-delay: 0.6s; background-color: #0F5AD3; }
    .dot-grid .dot:nth-child(7) { animation-delay: 0.7s; background-color: #00CDE1; }
    .dot-grid .dot:nth-child(8) { animation-delay: 0.8s; background-color: #00FF00; }
    
    @@keyframes pulse {
        0%, 100% { opacity: 0.2; transform: scale(0.8); }
        50% { opacity: 1; transform: scale(1.2); }
    }
</style>

<div class="d-flex flex-column" style="height: calc(100vh - 150px);">
    <div class="d-flex justify-end align-center mb-4">
        <MudSelect T="string" Value="@ChatState.SelectedModel" ValueChanged="OnModelChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mr-6" Style="max-width: 200px;">
            <MudSelectItem Value="@("openai/gpt-5.6-terra")">GPT-5.6 Terra</MudSelectItem>
            <MudSelectItem Value="@("openai/gpt-5.6-sol")">GPT-5.6 Sol</MudSelectItem>
            <MudSelectItem Value="@("openai/gpt-5.6-luna")">GPT-5.6 Luna</MudSelectItem>
            <MudSelectItem Value="@("openai/gpt-5.4-nano")">GPT-5.4 nano</MudSelectItem>
            <MudSelectItem Value="@("google-vertex/anthropic-claude-opus-4-8")">Claude Opus 4.8</MudSelectItem>
            <MudSelectItem Value="@("google-vertex/anthropic-claude-sonnet-5")">Claude Sonnet 5</MudSelectItem>
            <MudSelectItem Value="@("aws-claude-platform/claude-sonnet-4-6")">Claude Sonnet 4.6</MudSelectItem>
            <MudSelectItem Value="@("aws-claude-platform/claude-haiku-4-5")">Claude Haiku 4.5</MudSelectItem>
        </MudSelect>
        <MudSelect T="string" Value="@ChatState.SelectedAgent" ValueChanged="OnAgentChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 200px;">
            <MudSelectItem Value="@("GeneralAgent")">General Agent</MudSelectItem>
            <MudSelectItem Value="@("DbaAgent")">DBA Agent</MudSelectItem>
            <MudSelectItem Value="@("WindowsAdminAgent")">Windows Admin</MudSelectItem>
        </MudSelect>
    </div>

    <!-- Chat Messages Area -->
    <MudPaper Elevation="0" Class="flex-grow-1 overflow-y-auto pa-4 glass-panel d-flex flex-column gap-4" Style="margin-bottom: 16px;">
        @foreach (var message in _messages)
        {
            var isUser = message.User == "You";
            var isSystem = message.User == "System";
            var isError = message.IsError;
            
            <div class="d-flex @(isUser ? "justify-end" : "justify-start")">
                @if (isSystem)
                {
                    <MudText Typo="Typo.caption" Color="Color.Surface" Class="align-self-center">@message.Text</MudText>
                }
                else
                {
                    <div class="pa-3 @(isUser ? "user-msg" : (isError ? "error-msg" : "agent-msg"))" style="border-radius: 12px; max-width: 80%;">
                        <MudText Typo="Typo.subtitle2" Color="@(isUser ? Color.Primary : (isError ? Color.Error : Color.Info))" Class="mb-1">
                            @message.User
                        </MudText>
                        <MudText Typo="Typo.body2">@message.Text</MudText>
                        
                        @if (isError && !string.IsNullOrEmpty(message.ErrorDetail))
                        {
                            <MudText Typo="Typo.caption" Class="mt-2" Style="display:block; opacity: 0.8;">
                                @message.ErrorDetail
                            </MudText>
                        }
                    </div>
                }
            </div>
        }
        
        @if (_isWaiting && _currentStreamingMessage == null)
        {
            <div class="d-flex justify-start">
                <div class="pa-3 agent-msg" style="border-radius: 12px; max-width: 80%;">
                    <MudText Typo="Typo.subtitle2" Color="Color.Info" Class="mb-1">
                        @ChatState.SelectedAgent
                    </MudText>
                    <div class="dot-grid">
                        <div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div>
                        <div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div>
                    </div>
                </div>
            </div>
        }
    </MudPaper>

    <!-- Input Area -->
    <div class="d-flex gap-2">
        <MudTextField @bind-Value="_userInput" Placeholder="Type a message..." Variant="Variant.Outlined" Class="glass-input" Immediate="true" OnKeyDown="HandleKeyDown" />
        <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary" Variant="Variant.Filled" OnClick="SendMessage" Disabled="@(!IsConnected || _isWaiting)" />
    </div>
</div>

@code {
    private HubConnection? _hubConnection;
    private List<ChatMessage> _messages = new();
    private string _userInput = "";
    private ChatMessage? _currentStreamingMessage;
    private bool _isWaiting = false;

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += StateHasChanged;

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/chathub"))
            .Build();

        _hubConnection.On<string, string>("ReceiveMessage", (user, message) =>
        {
            _messages.Add(new ChatMessage { User = user, Text = message });
            _isWaiting = false;
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<string>("ReceiveToken", (token) =>
        {
            if (_currentStreamingMessage == null)
            {
                _currentStreamingMessage = new ChatMessage { User = ChatState.SelectedAgent, Text = "" };
                _messages.Add(_currentStreamingMessage);
            }
            _currentStreamingMessage.Text += token;
            _isWaiting = false;
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<ProblemDetailsDto>("ReceiveError", (problem) =>
        {
            _messages.Add(new ChatMessage 
            { 
                User = "System", 
                Text = problem.Title ?? "An error occurred", 
                IsError = true,
                ErrorDetail = problem.Detail 
            });
            _isWaiting = false;
            _currentStreamingMessage = null;
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On("StreamComplete", () => 
        {
            _currentStreamingMessage = null;
            _isWaiting = false;
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
        
        _messages.Add(new ChatMessage { User = "System", Text = "Connected to ADAS Orchestrator." });
    }

    public void Dispose()
    {
        ChatState.OnChange -= StateHasChanged;
    }

    private void OnModelChanged(string model)
    {
        ChatState.SetModel(model);
    }

    private void OnAgentChanged(string agent)
    {
        ChatState.SetAgent(agent);
    }

    private async Task SendMessage()
    {
        if (_hubConnection is not null && !string.IsNullOrWhiteSpace(_userInput))
        {
            var msg = _userInput;
            _userInput = "";
            _messages.Add(new ChatMessage { User = "You", Text = msg });
            _currentStreamingMessage = null; // Reset before streaming new message
            _isWaiting = true;
            StateHasChanged(); // Force the UI to show the loading indicator immediately
            
            try
            {
                // Use StreamMessage which streams tokens
                await _hubConnection.SendAsync("StreamMessage", msg, ChatState.SelectedModel, ChatState.SelectedAgent);
            }
            catch (Exception)
            {
                _isWaiting = false;
                _messages.Add(new ChatMessage { User = "System", Text = "Connection failed", IsError = true });
            }
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    public bool IsConnected => _hubConnection?.State == HubConnectionState.Connected;

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }

    private class ChatMessage
    {
        public string User { get; set; } = "";
        public string Text { get; set; } = "";
        public bool IsError { get; set; } = false;
        public string? ErrorDetail { get; set; }
    }

    private class ProblemDetailsDto
    {
        public string? Title { get; set; }
        public string? Detail { get; set; }
        public int Status { get; set; }
    }
}
